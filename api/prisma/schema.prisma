generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  nome     String // Adicione esta linha
  email    String @unique
  password String
}

model Cliente {
  id           Int            @id @default(autoincrement())
  nome         String
  telefone     String
  agendamentos Agendamento[]
}

model Servico {
  id        Int     @id @default(autoincrement())
  nome      String
  preco     Float
  duracao   Int      @default(30)
  agendamentos AgendamentoServico[]
}



model Agendamento {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  data       DateTime
  status     String   @default("AGENDADO")
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  servicos   AgendamentoServico[]
}

model AgendamentoServico {
  id             Int @id @default(autoincrement())
  agendamentoId  Int
  servicoId      Int

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id])
  servico     Servico     @relation(fields: [servicoId], references: [id])
}